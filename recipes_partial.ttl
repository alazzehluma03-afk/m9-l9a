@prefix :     <http://aispire.example.org/recipes/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ---- Cuisine classes (SKOS-labeled) ----

:Italian a :Cuisine ;
    skos:prefLabel "Italian" ;
    skos:altLabel  "italiano" .

:Thai a :Cuisine ;
    skos:prefLabel "Thai" ;
    skos:altLabel  "ไทย" .

# TODO: add at least one more cuisine class with skos:prefLabel + skos:altLabel
# so the 10 recipes you add can use a third cuisine. For Q2 in queries.py to
# exercise the altLabel path, at least one recipe must use a cuisine whose
# label only matches via skos:altLabel.

# ---- Ingredient classes (SKOS-labeled) ----

:eggplant a :Ingredient ;
    skos:prefLabel "eggplant" ;
    skos:altLabel  "aubergine" .

:basil a :Ingredient ;
    skos:prefLabel "basil" ;
    skos:altLabel  "sweet basil" .

:chili a :Ingredient ;
    skos:prefLabel "chili" ;
    skos:altLabel  "chile" .

# ---- Authors ----

:authorAlice a :Author ; :name "Alice Romano" .
:authorBruno a :Author ; :name "Bruno Tanaka" .

# TODO: add a few more :Author resources for your recipes to reference.

# ---- Recipes (5 pre-filled; extend to 15) ----

:recipe001 a :Recipe ;
    :name              "Eggplant Parmigiana" ;
    :cuisine           :Italian ;
    :primaryIngredient :eggplant ;
    :author            :authorAlice ;
    :year              2018 .

:recipe002 a :Recipe ;
    :name              "Basil Pesto Pasta" ;
    :cuisine           :Italian ;
    :primaryIngredient :basil ;
    :author            :authorAlice ;
    :year              2021 .

:recipe003 a :Recipe ;
    :name              "Thai Basil Stir Fry" ;
    :cuisine           :Thai ;
    :primaryIngredient :basil ;
    :author            :authorBruno ;
    :year              2022 .

:recipe004 a :Recipe ;
    :name              "Chili Garlic Noodles" ;
    :cuisine           :Thai ;
    :primaryIngredient :chili ;
    :author            :authorBruno ;
    :year              2019 .

:recipe005 a :Recipe ;
    :name              "Eggplant Curry" ;
    :cuisine           :Thai ;
    :primaryIngredient :eggplant ;
    :author            :authorBruno ;
    :year              2023 .

